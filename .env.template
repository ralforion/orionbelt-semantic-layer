# =============================================================================
# OrionBelt Semantic Layer — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.template .env
#
# All settings have sensible defaults. Uncomment and modify as required.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Log format: "console" (pretty, local dev), "json" (structured), "cloudrun" (JSON, no access logs)
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# REST API Configuration
# -----------------------------------------------------------------------------
API_SERVER_HOST=localhost
API_SERVER_PORT=8000
# Cloud Run injects PORT — takes precedence over API_SERVER_PORT
# PORT=8080

# Disable GET /v1/sessions endpoint (security hardening for public deployments)
# DISABLE_SESSION_LIST=false

# Public-doc surfaces. Set to false on non-demo deployments to hide /docs and
# /redoc (EXPOSE_API_DOCS) and/or /openapi.json (EXPOSE_OPENAPI_SCHEMA). The
# two flags are independent — keep EXPOSE_OPENAPI_SCHEMA=true if you still
# want the schema available for client codegen while hiding the human pages.
EXPOSE_API_DOCS=true
EXPOSE_OPENAPI_SCHEMA=true

# Default BCP-47 locale used by POST /v1/query/execute?format_values=true (and
# the TSV branch). Drives thousand/decimal separator choice. Empty → en-style
# (",": thousands, ".": decimals). Override per-request via the ``locale``
# query param (e.g. ``?locale=de``).
# DEFAULT_LOCALE=

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
# TTL in seconds before an idle session is purged (default: 1800 = 30 min)
SESSION_TTL_SECONDS=1800
# Absolute max session lifetime in seconds (default: 86400 = 24 h)
SESSION_MAX_AGE_SECONDS=86400
# Interval in seconds between cleanup sweeps (default: 60)
SESSION_CLEANUP_INTERVAL=60
# Global concurrent session cap — returns 429 when full (default: 500)
MAX_SESSIONS=500
# Max models a single session may hold — returns 429 when full (default: 10)
MAX_MODELS_PER_SESSION=10
# Max POST /sessions per IP per minute (default: 10)
SESSION_RATE_LIMIT=10

# -----------------------------------------------------------------------------
# Admin-Curated Model Pre-loading
# -----------------------------------------------------------------------------
# When MODEL_FILES is set, REST POST /v1/sessions/{id}/models returns 403 —
# the catalog is admin-managed.
#
# MODEL_FILES (multi-model, v2.4.0+)
#   Comma-separated list of OBML YAML paths. Each loads into its own internal
#   session, addressable by the OBML top-level `name:` field (fallback:
#   filename stem). Names are normalized — lowercase + spaces/dots/dashes →
#   underscores — and validated against ^[a-z][a-z0-9_]{0,62}$. A single path
#   is valid — that's the modern equivalent of the removed MODEL_FILE.
#
#   BI tools select the model via the Flight `database` catalog (DBeaver
#   "Database" field) or, in v2.5+, the pgwire `database=<name>` URL parameter.
#   Discover loaded names via `GET /v1/models`.
#
#   Local:  MODEL_FILES=/path/sales.yaml,/path/returns.yaml
#   Docker: MODEL_FILES=sales.obml.yml,returns.obml.yml   (relative to MODEL_DIR)
# MODEL_FILES=
#
# MODEL_FILE — REMOVED in v2.7.0. The startup logger emits a deprecation
# warning if it is still set in the environment. Replace with
# `MODEL_FILES=<same-path>`.
#
# MODEL_DIR — base directory for relative paths in MODEL_FILES
# (set automatically by the Docker entrypoint; rarely needed otherwise).
# MODEL_DIR=

# -----------------------------------------------------------------------------
# Standalone UI (Gradio)
# -----------------------------------------------------------------------------
# API URL when running the UI as a separate process/container
# API_BASE_URL=http://localhost:8000
# ASGI root path when UI runs behind a load balancer
# ROOT_PATH=

# =============================================================================
# Query Execution (requires ob-flight-extension)
# =============================================================================
# Enable POST /v1/query/execute endpoint (needs DB_VENDOR + credentials)
# QUERY_EXECUTE=false
# Default row limit when query has no explicit LIMIT (default: 1000)
# QUERY_DEFAULT_LIMIT=1000
# Connection pool size per dialect (default: 5)
# DB_POOL_SIZE=5
# Default database vendor for query execution
# DB_VENDOR=duckdb

# =============================================================================
# Freshness-Driven Result Cache
# =============================================================================
# See docs/guide/result-cache.md and design/PLAN_freshness_driven_cache.md.
# OFF by default — every cache get misses, every set is a no-op. Enable with
# CACHE_BACKEND=file plus a writable CACHE_DIR. For multi-replica deployments
# keep CACHE_BACKEND=noop until a Redis backend lands.

# Backend selection: "noop" (default, disabled) or "file"
# CACHE_BACKEND=noop
# Cache directory for the file backend (DuckDB metadata + Parquet payloads).
# Mount on persistent storage to survive restarts.
# CACHE_DIR=./cache
# Hard cap on any TTL, in seconds (default: 86400 = 24 h)
# CACHE_MAX_TTL_SECONDS=86400
# Minimum TTL — derived TTLs below this skip caching (default: 5 s)
# CACHE_MIN_TTL_SECONDS=5
# Skip caching results larger than this (default: 10 MB)
# CACHE_MAX_VALUE_BYTES=10485760
# Capacity limit before LRU eviction (default: 5 GB)
# CACHE_MAX_DISK_BYTES=5368709120
# Periodic sweep cadence in seconds (default: 86400 = 1 day).
# Lazy TTL check on read keeps user-facing freshness correct; the sweep
# only reclaims disk for unread expired entries and runs LRU capacity eviction.
# CACHE_SWEEP_INTERVAL_SECONDS=86400
# How to handle queries touching dataObjects with no refresh: block.
# "no_cache" (default) skips caching; "default_ttl" uses the value below.
# CACHE_UNKNOWN_FRESHNESS_POLICY=no_cache
# CACHE_UNKNOWN_FRESHNESS_DEFAULT_TTL=300

# Bearer token for POST /v1/heartbeat. Required to enable the endpoint —
# leaving it unset returns 404 from the heartbeat route.
# HEARTBEAT_AUTH_TOKEN=

# =============================================================================
# Arrow Flight SQL Server (gRPC — for DBeaver, Tableau, Power BI)
# =============================================================================
# Enable gRPC Flight SQL server on FLIGHT_PORT (implies QUERY_EXECUTE=true)
# FLIGHT_ENABLED=false
# FLIGHT_PORT=8815
# FLIGHT_AUTH_MODE=none
# FLIGHT_API_TOKEN=
#
# v2.4.0 governance is closed-by-design. OBSL only ever emits SQL it
# compiled itself; raw warehouse SQL always rejects with RAW_SQL_REJECTED
# and write operations (DDL/DML/TCL) with WRITE_OPERATION_REJECTED.
# There are intentionally no FLIGHT_ALLOW_* flags.
#
# In multi-model mode (MODEL_FILES, see above), BI tools select which
# model to query via the connection's Database / Catalog field. The Arrow
# Flight SQL JDBC driver maps this to a `database` gRPC metadata header.
# Pyarrow clients pass it via FlightCallOptions(headers=[(b'database', b'<name>')]).

# -----------------------------------------------------------------------------
# Database Credentials (used by Flight SQL and POST /v1/query/execute)
# -----------------------------------------------------------------------------
# Uncomment the section matching your DB_VENDOR.

# -- BigQuery --
# BIGQUERY_PROJECT=my-gcp-project
# BIGQUERY_LOCATION=US
# BIGQUERY_CREDENTIALS_FILE=/path/to/service-account.json

# -- DuckDB / MotherDuck --
# DUCKDB_DATABASE=:memory:

# -- PostgreSQL --
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DBNAME=mydb
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SCHEMA=public

# -- Snowflake --
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_WAREHOUSE=

# -- ClickHouse --
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default

# -- Dremio --
# DREMIO_HOST=localhost
# DREMIO_PORT=32010
# DREMIO_USERNAME=
# DREMIO_PASSWORD=

# -- Databricks --
# DATABRICKS_SERVER_HOSTNAME=
# DATABRICKS_HTTP_PATH=
# DATABRICKS_ACCESS_TOKEN=
# DATABRICKS_CATALOG=hive_metastore
# DATABRICKS_SCHEMA=default
