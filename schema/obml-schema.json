{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/obml/schema",
  "title": "OBML",
  "description": "A markup language to define the OrionBelt Semantic Layer",
  "definitions": {
"customExtension": {
      "type": "object",
      "description": "Vendor-keyed extension data — opaque to OrionBelt",
      "properties": {
        "vendor": {
          "type": "string",
          "description": "Vendor or format identifier (e.g. OSI, GOVERNANCE)"
        },
        "data": {
          "type": "string",
          "description": "Opaque data payload (typically JSON string)"
        }
      },
      "required": ["vendor", "data"],
      "additionalProperties": false
    },
    "dataObject": {
      "type": "object",
      "description": "Unique Data Object Name in the OrionBelt Model",
      "properties": {
        "database": {
          "type": "string",
          "description": "Database Name"
        },
        "schema": {
          "type": "string",
          "description": "Schema Name in Database"
        },
        "code": {
          "type": "string",
          "description": "Database Table Name, View Name or SELECT statement"
        },
        "columns": {
          "type": "object",
          "description": "Selected Columns from Database Object to be used in OrionBelt. Column names must be unique within each data object.",
          "patternProperties": {
            ".": {
              "$ref": "#/definitions/column"
            }
          },
          "additionalProperties": false,
          "minProperties": 1
        },
        "joins": {
          "type": "array",
          "description": "Connect this Data Object with other Data Objects by defining Joins",
          "items": {
            "$ref": "#/definitions/join"
          }
        },
        "description": {
          "type": "string",
          "description": "Business description of this data object (semantic layer metadata)"
        },
        "comment": {
          "type": "string",
          "description": "Physical database comment (from COMMENT ON TABLE)"
        },
        "owner": {
          "type": "string",
          "description": "Owner or responsible party for this data object"
        },
        "synonyms": {
          "type": "array",
          "description": "Alternative names or terms for this data object (LLM hints)",
          "items": { "type": "string" }
        },
        "customExtensions": {
          "type": "array",
          "description": "Vendor-keyed extension data",
          "items": { "$ref": "#/definitions/customExtension" }
        }
      },
      "required": ["code", "columns"],
      "additionalProperties": false
    },
    "dataType": {
      "description": "OrionBelt internal Data Type",
      "enum": ["string", "json", "int", "float", "date", "time", "time_tz", "timestamp", "timestamp_tz", "boolean"]
    },
    "timeGrain": {
      "description": "used to trunc the a date value to aggregate along a date hierarchy",
      "enum": [
        "year",
        "year-end",
        "quarter",
        "quarter-end",
        "month",
        "month-end",
        "week",
        "week-end",
        "day",
        "hour",
        "minute",
        "second"
      ]
    },
    "numClass": {
      "description": "Numeric classification hint for LLMs: categorical (IDs/codes — group/filter only), additive (sum-safe — amounts, quantities), non_additive (rates, %, ratios — don't assume SUM)",
      "enum": ["categorical", "additive", "non-additive"]
    },
    "column": {
      "type": "object",
      "description": "Unique Column Name in that Data Object",
      "properties": {
        "code": {
          "type": "string"
        },
        "abstractType": {
          "$ref": "#/definitions/dataType"
        },
        "sqlType": {
          "type": "string",
          "description": "Informational: the SQL data type of the column (e.g. VARCHAR, INTEGER, NUMERIC(10,2))"
        },
        "sqlPrecision": {
          "type": "integer",
          "description": "Informational: numeric precision",
          "minimum": 1
        },
        "sqlScale": {
          "type": "integer",
          "description": "Informational: numeric scale",
          "minimum": 0
        },
        "numClass": {
          "$ref": "#/definitions/numClass"
        },
        "description": {
          "type": "string",
          "description": "Business description of this column (semantic layer metadata)"
        },
        "comment": {
          "type": "string",
          "description": "Physical database comment (from COMMENT ON COLUMN)"
        },
        "owner": {
          "type": "string",
          "description": "Owner or responsible party for this column"
        },
        "synonyms": {
          "type": "array",
          "description": "Alternative names or terms for this column (LLM hints)",
          "items": { "type": "string" }
        },
        "customExtensions": {
          "type": "array",
          "description": "Vendor-keyed extension data",
          "items": { "$ref": "#/definitions/customExtension" }
        }
      },
      "required": ["code", "abstractType"],
      "additionalProperties": false,
      "if": {
        "not": {
          "properties": { "abstractType": { "enum": ["int", "float"] } },
          "required": ["abstractType"]
        }
      },
      "then": {
        "not": { "required": ["numClass"] }
      }
    },
    "join": {
      "type": "object",
      "properties": {
        "joinType": {
          "description": "Join Cardinality",
          "enum": ["many-to-one", "one-to-one", "many-to-many"]
        },
        "joinTo": {
          "type": "string",
          "description": "Join-to Data Object Name"
        },
        "columnsFrom": {
          "type": "array",
          "contains": {
            "type": "string"
          },
          "minItems": 1
        },
        "columnsTo": {
          "type": "array",
          "contains": {
            "type": "string"
          },
          "minItems": 1
        },
        "secondary": {
          "type": "boolean",
          "description": "Mark this join as a secondary (alternative) path. Secondary joins are excluded from multipath/cycle validation.",
          "default": false
        },
        "pathName": {
          "type": "string",
          "description": "Unique name for this join path within the (source, target) pair. Required when secondary is true. Used in queries via usePathNames to select this join."
        }
      },
      "required": ["joinType", "joinTo", "columnsFrom", "columnsTo"],
      "additionalProperties": false
    },
    "queryColumn": {
      "type": "object",
      "description": "Column reference by dataObject + column pair",
      "properties": {
        "dataObject": {
          "type": "string",
          "description": "OrionBelt Data Object Name"
        },
        "column": {
          "type": "string",
          "description": "OrionBelt Column Name"
        }
      },
      "required": ["dataObject", "column"],
      "additionalProperties": false
    },
    "operator": {
      "description": "Filter operation code (measure-level filters)",
      "enum": [
        "equals",
        "notequals",
        "inlist",
        "notinlist",
        "contains",
        "notcontains",
        "gt",
        "gte",
        "lt",
        "lte",
        "set",
        "notset",
        "between",
        "notbetween",
        "like",
        "notlike",
        "starts_with",
        "ends_with"
      ]
    },
    "staticFilterOperator": {
      "description": "Filter operator for static model filters — supports both OBML and SQL-style naming",
      "enum": [
        "equals", "notequals", "inlist", "notinlist",
        "contains", "notcontains", "gt", "gte", "lt", "lte",
        "set", "notset", "between", "notbetween",
        "like", "notlike", "starts_with", "ends_with",
        "=", "!=", ">", ">=", "<", "<=",
        "in", "not_in", "is_null", "is_not_null"
      ]
    },
    "parameterValue": {
      "type": "object",
      "description": "Value to apply for filtering",
      "properties": {
        "dataType": {
          "description": "defines datatype of parameter value",
          "$ref": "#/definitions/dataType"
        },
        "isNull": {
          "description": "used to include NULL in inlist, notinlist, if set true other value properties are ignored",
          "type": "boolean"
        },
        "valueString": { "type": "string" },
        "valueInt": { "type": "integer" },
        "valueFloat": { "type": "number" },
        "valueDate": {
          "description": "ISO 8601 date string YYYY-MM-DD (2021-02-18)",
          "type": "string"
        },
        "valueTime": {
          "description": "ISO 8601 time string HH:mm:ss.sss (10:44:23.000)",
          "type": "string"
        },
        "valueTimeTZ": {
          "description": "ISO 8601 time string with Timezone HH:mm:ss.sss±hh:mm (10:44:23.000+01:00)",
          "type": "string"
        },
        "valueTimestamp": {
          "description": "ISO 8601 timestamp string in UTC YYYY-MM-DDTHH:mm:ss.sss (2021-02-18T10:44:23.000)",
          "type": "string"
        },
        "valueTimestampTZ": {
          "description": "ISO 8601 timestamp string with Timezone YYYY-MM-DDTHH:mm:ss.sss±hh:mm (2021-02-18T10:44:23.000+01:00)",
          "type": "string"
        },
        "valueMillis": {
          "description": "can used for timestamp fields, millisec in UTC (e.g. in Snowflake: TO_TIMESTAMP('1604954053'))",
          "type": "integer"
        },
        "valueBoolean": { "type": "boolean" }
      },
      "required": ["dataType"]
    },
    "dynamicDatePart": {
      "enum": ["year", "month", "quarter", "week", "day", "hour", "minute", "second"]
    },
    "dynamicDateCalcType": {
      "enum": [
        "boy",
        "bopy",
        "bom",
        "bopm",
        "boq",
        "bopq",
        "bow",
        "bopw",
        "eoy",
        "eom",
        "eoq",
        "eow",
        "today",
        "yesterday"
      ]
    },
    "dynamicDateCalcRangeType": {
      "enum": [
        "eytd",
        "ytd",
        "emtd",
        "mtd",
        "qtd",
        "wtd",
        "pytd",
        "pmtd",
        "pqtd",
        "pwtd",
        "l12m",
        "l90d",
        "l30d",
        "l7d",
        "py",
        "pm",
        "pq",
        "pw",
        "today",
        "yesterday"
      ]
    },
    "filter": {
      "type": "object",
      "description": "Filter definition",
      "properties": {
        "column": {
          "$ref": "#/definitions/queryColumn"
        },
        "operator": {
          "$ref": "#/definitions/operator"
        },
        "values": {
          "type": "array",
          "description": "no value for set/notSet, one value for comparisons, two values for between/notBetween, list of values for contains/notContains",
          "items": {
            "$ref": "#/definitions/parameterValue"
          }
        },
        "timeGrain": {
          "$ref": "#/definitions/timeGrain"
        },
        "dynamicDate": {
          "type": "object",
          "properties": {
            "part": {
              "$ref": "#/definitions/dynamicDatePart"
            },
            "offset": {
              "type": "integer"
            }
          },
          "required": ["part", "offset"]
        },
        "dynamicDateRange": {
          "type": "object",
          "properties": {
            "part": {
              "$ref": "#/definitions/dynamicDatePart"
            },
            "offsetBegin": {
              "type": "integer"
            },
            "offsetEnd": {
              "type": "integer"
            }
          },
          "required": ["part", "offsetBegin", "offsetEnd"]
        },
        "dynamicDateCalc": {
          "type": "object",
          "properties": {
            "dynamicDateType": {
              "$ref": "#/definitions/dynamicDateCalcType"
            }
          },
          "required": ["dynamicDateType"]
        },
        "dynamicDateCalcRange": {
          "type": "object",
          "properties": {
            "dynamicDateType": {
              "$ref": "#/definitions/dynamicDateCalcRangeType"
            }
          },
          "required": ["dynamicDateType"]
        }
      },
      "required": ["column", "operator"]
    },
    "filterGroup": {
      "type": "object",
      "description": "A group of filters combined with AND or OR logic, supporting recursive nesting",
      "properties": {
        "logic": {
          "description": "Boolean combination logic for child filters",
          "enum": ["and", "or"],
          "default": "and"
        },
        "filters": {
          "type": "array",
          "description": "Child filters (leaf filters or nested filter groups)",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/filter" },
              { "$ref": "#/definitions/filterGroup" }
            ]
          },
          "minItems": 1
        },
        "negated": {
          "type": "boolean",
          "description": "When true, negates the entire group: NOT (filter1 AND/OR filter2)",
          "default": false
        }
      },
      "required": ["filters"],
      "additionalProperties": false
    },
    "dimension": {
      "type": "object",
      "description": "Dimension definition",
      "properties": {
        "dataObject": {
          "type": "string",
          "description": "OrionBelt Data Object Name"
        },
        "column": {
          "type": "string",
          "description": "OrionBelt Column Name"
        },
        "resultType": {
          "$ref": "#/definitions/dataType",
          "description": "Data type of the result (informative only, not used for SQL generation)"
        },
        "label": {
          "type": "string"
        },
        "timeGrain": {
          "$ref": "#/definitions/timeGrain"
        },
        "description": {
          "type": "string",
          "description": "Business description of this dimension"
        },
        "format": {
          "type": "string"
        },
        "group": {
          "type": "array",
          "description": "used in case of a dimension group, list of fields",
          "items": {
            "$ref": "#/definitions/queryColumn"
          },
          "minItems": 2
        },
        "owner": {
          "type": "string",
          "description": "Owner or responsible party for this dimension"
        },
        "synonyms": {
          "type": "array",
          "description": "Alternative names or terms for this dimension (LLM hints)",
          "items": { "type": "string" }
        },
        "customExtensions": {
          "type": "array",
          "description": "Vendor-keyed extension data",
          "items": { "$ref": "#/definitions/customExtension" }
        }
      },
      "required": ["dataObject", "column"],
      "additionalProperties": false
    },
    "measure": {
      "type": "object",
      "description": "Measure definition",
      "properties": {
        "columns": {
          "type": "array",
          "description": "Columns used in Measure for Aggregation",
          "items": {
            "$ref": "#/definitions/queryColumn"
          }
        },
        "label": {
          "type": "string"
        },
        "resultType": {
          "$ref": "#/definitions/dataType",
          "description": "Data type of the result (informative only, not used for SQL generation)"
        },
        "aggregation": {
          "type": "string",
          "description": "Aggregation Function (sum,min,max,any_value,median,mode,listagg, etc.)"
        },
        "distinct": {
          "type": "boolean",
          "description": "DISTINCT clause"
        },
        "delimiter": {
          "type": "string",
          "description": "Delimiter Field for List Functions (LISTAGG)"
        },
        "withinGroup": {
          "type": "object",
          "description": "WITHIN GROUP clause to specify column for ordering in LISTAGG",
          "properties": {
            "column": {
              "$ref": "#/definitions/queryColumn"
            },
            "order": {
              "enum": ["ASC", "DESC"],
              "default": "ASC"
            }
          },
          "required": ["column"],
          "additionalProperties": false
        },
        "allowFanOut": {
          "type": "boolean",
          "description": "allow fan out for this measure, only applicable if measures can't reach dimensions but dimensions can reach measures for a specific grain"
        },
        "reduceToRelationDimensionality": {
          "type": "boolean",
          "description": "reduce to relation dimensionality, only applicable `AllowFanOut` is true and if measures can't reach dimensions but dimensions can reach measures for a specific grain"
        },
        "total": {
          "type": "boolean",
          "description": "will use the total value of the measure"
        },
        "expression": {
          "type": "string",
          "description": "template string with {[DataObject].[Column]} placeholders for measure expression"
        },
        "functions": {
          "type": "array",
          "contains": {
            "type": "string"
          }
        },
        "description": {
          "type": "string",
          "description": "Business description of this measure"
        },
        "format": {
          "type": "string"
        },
        "filters": {
          "type": "array",
          "description": "Filters applied to this measure (combined with AND by default). Supports leaf filters and filter groups with AND/OR/NOT logic.",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/filter" },
              { "$ref": "#/definitions/filterGroup" }
            ]
          }
        },
        "owner": {
          "type": "string",
          "description": "Owner or responsible party for this measure"
        },
        "synonyms": {
          "type": "array",
          "description": "Alternative names or terms for this measure (LLM hints)",
          "items": { "type": "string" }
        },
        "customExtensions": {
          "type": "array",
          "description": "Vendor-keyed extension data",
          "items": { "$ref": "#/definitions/customExtension" }
        }
      },
      "required": ["aggregation"],
      "additionalProperties": false
    },
    "cumulativeAggType": {
      "description": "Window aggregation function for cumulative metrics",
      "enum": ["sum", "avg", "min", "max", "count"]
    },
    "grainToDate": {
      "description": "Reset boundary for grain-to-date cumulative metrics",
      "enum": ["year", "quarter", "month", "week"]
    },
    "periodOverPeriodComparison": {
      "description": "Comparison type for period-over-period metrics",
      "enum": ["ratio", "difference", "previousValue", "percentChange"]
    },
    "periodOverPeriod": {
      "type": "object",
      "description": "Period-over-period configuration — compares a measure against a prior time period",
      "properties": {
        "timeDimension": {
          "type": "string",
          "description": "Name of the time dimension used for period comparison (must be in SELECT)"
        },
        "grain": {
          "$ref": "#/definitions/timeGrain",
          "description": "Time grain for the date spine (e.g. month, quarter, year)"
        },
        "offset": {
          "type": "integer",
          "description": "Number of periods to look back (negative = past, e.g. -1 = previous period)",
          "default": -1
        },
        "offsetGrain": {
          "$ref": "#/definitions/timeGrain",
          "description": "Unit for the offset (e.g. year for YoY, month for MoM)"
        },
        "comparison": {
          "$ref": "#/definitions/periodOverPeriodComparison",
          "description": "How to compare current vs previous period value",
          "default": "percentChange"
        }
      },
      "required": ["timeDimension", "grain", "offsetGrain"],
      "additionalProperties": false
    },
    "metric": {
      "type": "object",
      "description": "Metric definition. A derived metric (expression referencing measures), a cumulative metric (window function over a measure), or a period-over-period metric (comparing a measure across time periods).",
      "properties": {
        "label": {
          "type": "string"
        },
        "type": {
          "description": "Metric category: derived (expression-based), cumulative (window function), or period_over_period (time comparison)",
          "enum": ["derived", "cumulative", "period_over_period"],
          "default": "derived"
        },
        "expression": {
          "type": "string",
          "description": "Template string with {[Measure Name]} placeholders (required for derived and period_over_period metrics)"
        },
        "measure": {
          "type": "string",
          "description": "Name of base measure (required for cumulative metrics)"
        },
        "timeDimension": {
          "type": "string",
          "description": "Dimension used for ordering (required for cumulative metrics, must be a date/timestamp dimension)"
        },
        "cumulativeType": {
          "$ref": "#/definitions/cumulativeAggType",
          "description": "Window aggregation function (default: sum)",
          "default": "sum"
        },
        "window": {
          "type": "integer",
          "description": "Rolling window size in periods (omit for unbounded running total). Mutually exclusive with grainToDate.",
          "minimum": 1
        },
        "grainToDate": {
          "$ref": "#/definitions/grainToDate",
          "description": "Reset boundary for grain-to-date (e.g. month for MTD). Mutually exclusive with window."
        },
        "periodOverPeriod": {
          "$ref": "#/definitions/periodOverPeriod",
          "description": "Period-over-period configuration (required for period_over_period metrics)"
        },
        "description": {
          "type": "string",
          "description": "Business description of this metric"
        },
        "format": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "description": "Owner or responsible party for this metric"
        },
        "synonyms": {
          "type": "array",
          "description": "Alternative names or terms for this metric (LLM hints)",
          "items": { "type": "string" }
        },
        "customExtensions": {
          "type": "array",
          "description": "Vendor-keyed extension data",
          "items": { "$ref": "#/definitions/customExtension" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "cumulative" } },
            "required": ["type"]
          },
          "then": {
            "required": ["measure", "timeDimension"],
            "not": {
              "required": ["window", "grainToDate"]
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "period_over_period" } },
            "required": ["type"]
          },
          "then": {
            "required": ["expression", "periodOverPeriod"]
          }
        },
        {
          "if": {
            "not": {
              "properties": { "type": { "enum": ["cumulative", "period_over_period"] } },
              "required": ["type"]
            }
          },
          "then": {
            "required": ["expression"]
          }
        }
      ],
      "additionalProperties": false
    },
    "locale": {
      "type": "object",
      "properties": {
        "timezone": {
          "type": "string",
          "default": "Europe/London"
        },
        "number": {
          "type": "object",
          "properties": {
            "deciamlSep": {
              "type": "string",
              "default": "."
            },
            "thousandSep": {
              "type": "string",
              "default": ","
            }
          }
        },
        "calendar": {
          "type": "object",
          "properties": {
            "monthNames": {
              "type": "array",
              "contains": {
                "type": "string"
              },
              "default": [
                "January",
                "February",
                "March",
                "April",
                "May",
                "June",
                "July",
                "August",
                "September",
                "October",
                "November",
                "December"
              ],
              "minItems": 12,
              "maxItems": 12
            },
            "monthNamesAbbr": {
              "type": "array",
              "contains": {
                "type": "string"
              },
              "default": ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"],
              "minItems": 12,
              "maxItems": 12
            },
            "dayNames": {
              "type": "array",
              "contains": {
                "type": "string"
              },
              "default": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
              "minItems": 7,
              "maxItems": 7
            },
            "dayNamesAbbr": {
              "type": "array",
              "contains": {
                "type": "string"
              },
              "default": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
              "minItems": 7,
              "maxItems": 7
            }
          }
        },
        "formats": {
          "type": "object",
          "properties": {
            "number": {
              "type": "string",
              "default": "#,##0.00"
            },
            "numberInt": {
              "type": "string",
              "default": "#,##0"
            },
            "money": {
              "type": "string",
              "default": "$#,###.00"
            },
            "date": {
              "type": "string",
              "default": "yyyy-mm-dd"
            },
            "dateTime": {
              "type": "string",
              "default": "yyyy-mm-dd hh:mm:ss"
            },
            "time": {
              "type": "string",
              "default": "hh:mm:ss"
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "version": {
      "enum": [1.0]
    },
    "description": {
      "type": "string",
      "description": "Business description of this semantic model"
    },
"dataObjects": {
      "type": "object",
      "description": "Data Object Names in the OrionBelt Model",
      "patternProperties": {
        ".": {
          "$ref": "#/definitions/dataObject"
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "dimensions": {
      "type": "object",
      "description": "Dimensions for use in Queries",
      "patternProperties": {
        ".": {
          "$ref": "#/definitions/dimension"
        }
      },
      "additionalProperties": false
    },
    "measures": {
      "type": "object",
      "description": "Measures for use in Queries or referenced by Metrics",
      "patternProperties": {
        ".": {
          "$ref": "#/definitions/measure"
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "description": "Metrics for use in Queries",
      "patternProperties": {
        ".": {
          "$ref": "#/definitions/metric"
        }
      },
      "additionalProperties": false
    },
    "locale": {
      "$ref": "#/definitions/locale"
    },
    "owner": {
      "type": "string",
      "description": "Owner or responsible party for this model"
    },
    "filters": {
      "type": "array",
      "description": "Static WHERE filters applied to every query against this model",
      "items": {
        "type": "object",
        "properties": {
          "dataObject": {
            "type": "string",
            "description": "Data object containing the filter column"
          },
          "column": {
            "type": "string",
            "description": "Column name within the data object"
          },
          "operator": {
            "$ref": "#/definitions/staticFilterOperator"
          },
          "value": {
            "description": "Single filter value. Dates and timestamps use ISO 8601 strings (e.g. '2026-01-01', '2026-01-01T14:30:00Z'). Bare YAML dates are auto-coerced to ISO strings at load time.",
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          },
          "values": {
            "type": "array",
            "description": "List of filter values (for in/between operators). Dates use ISO 8601 strings.",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          }
        },
        "required": ["dataObject", "column", "operator"],
        "additionalProperties": false
      }
    },
    "extends": {
      "type": "array",
      "description": "List of OBML files to merge as analytical layers (dimensions, measures, metrics). Extend files must not contain dataObjects.",
      "items": { "type": "string" }
    },
    "inherits": {
      "type": "string",
      "description": "Path to a parent OBML model to inherit all definitions from. The parent provides dataObjects, joins, dimensions, measures, metrics, and filters. The child can add or override analytical definitions and append static filters."
    },
    "customExtensions": {
      "type": "array",
      "description": "Vendor-keyed extension data at model level",
      "items": { "$ref": "#/definitions/customExtension" }
    },
    "additionalProperties": false
  },
  "required": ["version"],
  "allOf": [
    {
      "if": {
        "not": {
          "anyOf": [
            { "required": ["extends"] },
            { "required": ["inherits"] }
          ]
        }
      },
      "then": {
        "required": ["dataObjects"]
      }
    },
    {
      "not": {
        "required": ["extends", "inherits"]
      }
    },
    {
      "if": { "required": ["inherits"] },
      "then": {
        "not": { "required": ["dataObjects"] }
      }
    }
  ]
}
